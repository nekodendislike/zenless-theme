		"editorSuggestWidget.selectedForeground": "#000000",
		"editorSuggestWidget.selectedBackground": "#22bdcc",
		"editorSuggestWidget.selectedIconForeground": "#000000",
		"editorHoverWidget.border": "#0d474b",
