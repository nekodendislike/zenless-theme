		"diffEditor.insertedTextBackground": "#afce3233",
		"diffEditor.insertedLineBackground": "#afce3233",
		"diffEditor.removedTextBackground": "#ca4b3d33",
		"diffEditor.removedLineBackground": "#ca4b3d33",
