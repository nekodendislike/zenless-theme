		"merge.currentContentBackground": "#57a19999",
		"merge.incomingHeaderBackground": "#649eff99",
		"merge.incomingContentBackground": "#00265699",
		"terminal.hoverHighlightBackground": "#fcdc0066"
	},
	"semanticHighlighting": true,
	"tokenColors": [
		{
			"name": "type",
			"scope": [
				"constant.language",
				"keyword.operator.expression",
				"storage.type",
				"support.type"
			],
			"settings": {
				"foreground": "#5588ff"
			}
		},
		{
			"name": "number",
			"scope": [
				"constant.numeric"
			],
			"settings": {
				"foreground": "#84f2f3"
			}
		},
		{
			"name": "type name",
			"scope": [
				"entity.name.type"
			],
			"settings": {
				"foreground": "#7ee7c0"
			}
		},
		{
			"name": "function",
			"scope": [
				"entity.name.function"
			],
			"settings": {
				"foreground": "#afce32"
			}
		},
		{
			"name": "html tag",
			"scope": [
				"entity.name.tag"
			],
			"settings": {
				"foreground": "#22bdcc"
			}
		},
		{
			"name": "html attribute",
			"scope": [
				"entity.other.attribute-name"
			],
			"settings": {
				"foreground": "#91daed"
			}
		},
		{
			"name": "invalid",
			"scope": "invalid",
			"settings": {
				"foreground": "#ff2233"
			}
		},
		{
			"name": "comment",
			"scope": [
				"comment"
			],
			"settings": {
				"foreground": "#404f58"
			}
		},
		{
			"name": "string",
			"scope": [
				"string"
			],
			"settings": {
				"foreground": "#ff8916"
			}
		},
		{
			"name": "keyword control",
			"scope": [
				"keyword.control"
			],
			"settings": {
				"foreground": "#cc83eb"
			}
		},
		{
			"name": "keyword new",
			"scope": [
				"keyword.operator.new"
			],
			"settings": {
				"foreground": "#649eff"
			}
		},
		{
			"name": "=",
			"scope": [
				"keyword.operator.assignment"
			],
			"settings": {
				"foreground": "#22bdcc"
			}
		},
		{
			"name": "md header",
			"scope": [
				"markup.heading"
			],
			"settings": {
				"foreground": "#91daed",
				"fontStyle": "bold"
			}
		},
		{
			"name": "property?",
			"scope": [
				"meta.object.member"
			],
			"settings": {
				"foreground": "#91daed"
			}
		},
		{
			"name": "meta block",
			"scope": [
				"meta.block"
			],
			"settings": {
				"foreground": "#22bdcc"
			}
		},
		{
			"scope": "emphasis",
			"settings": {
				"fontStyle": "italic"
			}
		},
		{
			"scope": "strong",
			"settings": {
				"fontStyle": "bold"
			}
		},
		{
			"name": "python",
			"scope": [
				"source.python"
			],
			"settings": {
				"foreground": "#649eff"
			}
		},
		{
			"name": "async",
			"scope": [
				"storage.modifier.async"
			],
			"settings": {
				"foreground": "#22bdcc"
			}
		},
		{
			"name": "modi",
			"scope": [
				"storage.modifier"
			],
			"settings": {
				"foreground": "#22bdcc"
			}
		},
		{
			"name": "variable other",
			"scope": [
				"variable.other.object",
				"variable.other.object.property",
				"variable.other.property",
				"variable.other.readwrite",
				"variable.other.readwrite.alias"
			],
			"settings": {
				"foreground": "#91daed"
			}
		},
		{
			"name": "variable constant",
			"scope": [
				"variable.other.constant"
			],
			"settings": {
				"foreground": "#22bdcc"
			}
		},
		{
			"name": "property",
			"scope": [
				"variable.parameter"
			],
			"settings": {
				"foreground": "#91daed"
			}
		}
	],
	"semanticTokenColors": {
		"enumMember": {
			"foreground": "#0d75d9"
		},
		"variable.constant": {
			"foreground": "#d19a66"
		},
		"variable.defaultLibrary": {
			"foreground": "#e5c07b"
		}
	}
}